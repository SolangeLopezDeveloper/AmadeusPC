<!DOCTYPE html>
<html lang="es">

<%- include('./partials/head.ejs',{otherScript: include('./partials/scripts.ejs',{view:'Home'})}) %>

<body data-idUser="<%= locals.userLogin?.id %>">
<main>
    <%- include('./partials/header.ejs') %>

    <div class="main main__index">

        <!-- Hero con buscador -->
     <section class="home__hero">
    <div class="home__hero--content">
        <h1>La mejor tecnología,<br><span>al mejor precio.</span></h1>
        
        <form class="home__hero--search" action="/search" method="GET">
            <input type="text" name="keywords" placeholder="¿Qué estás buscando?" value="<%= locals.keywords || '' %>">
            <button type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
        </form> 
        
        <p>Procesadores, placas de video, periféricos y más.</p>
    </div>
</section>
     
        
                   <!--  <form class="home__hero--search" action="/search" method="GET">
                    <input type="text" name="keywords" placeholder="Buscar productos...">
                    <button type="submit"><i class="fa-solid fa-magnifying-glass"></i> Buscar</button>
                </form> -->
      

        <!-- Beneficios -->
        <section class="home__benefits">
            <div class="home__benefit">
                <i class="fa-regular fa-credit-card"></i>
                <span>Hasta 12 cuotas</span>
            </div>
            <div class="home__benefit">
                <i class="fa-sharp fa-solid fa-truck"></i>
                <span>Envío a domicilio</span>
            </div>
            <div class="home__benefit">
                <i class="fa-solid fa-shield-halved"></i>
                <span>Compra 100% segura</span>
            </div>
        </section>

        <!-- Banner carrusel -->
        <section class="home__banner">
            <div id="carouselBanner" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#carouselBanner" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#carouselBanner" data-bs-slide-to="1"></button>
                    <button type="button" data-bs-target="#carouselBanner" data-bs-slide-to="2"></button>
                </div>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/images/home/BANNER-OFICIAL-INTEL.png" class="d-block w-100" alt="Banner Intel">
                    </div>
                    <div class="carousel-item">
                        <img src="/images/home/web-banner.png" class="d-block w-100" alt="Banner">
                    </div>
                    <div class="carousel-item">
                        <img src="/images/home/carrete3.jpg" class="d-block w-100" alt="Banner">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselBanner" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselBanner" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </section>

        <!-- Productos nuevos -->
        <section class="home__products">
            <div class="home__products--header">
                <h2>Productos de Última Generación</h2>
                <a href="/productos/productos" class="home__products--ver-mas">Ver todos →</a>
            </div>
            <div class="home__products--grid" id="container-newest-card"></div>
            <div class="paginator">
                <%- include('./partials/paginator.ejs') %>
            </div>
        </section>

        <!-- Ofertas -->
        <section class="home__offers">
            <div class="home__products--header">
                <h2>Ofertas Imperdibles</h2>
            </div>
            <div class="home__offers--controls">
                <button class="btn control-prev" role="button" data-slide="prev">
                    <i class="fa-solid fa-circle-chevron-left"></i>
                </button>
                <div class="home__offers--grid" id="container-offer-card"></div>
                <button class="btn control-next" role="button" data-slide="next">
                    <i class="fa-solid fa-circle-chevron-right"></i>
                </button>
            </div>
        </section>

        <!-- Marcas -->
        <section class="home__brands">
            <p>Las mejores marcas en AMADEUS</p>
            <%- include('./partials/carreteMarcas.ejs') %>
        </section>

    </div>
</main>

<%- include('./partials/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
    crossorigin="anonymous"></script>
<script src="/js/paginatorIndex.js"></script>
<script src="/js/paginatorIndexOffer.js"></script>
<script src="/js/favorites.js"></script>
<script src="/js/carreteMarcas.js"></script>

<script>
    // Burguer menu toggle
    const burguer = document.getElementById('burguer-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    burguer.addEventListener('click', () => {
        mobileMenu.classList.toggle('active');
        burguer.classList.toggle('active');
    });
</script>
</body>
</html>
